# THIS IS A CONTEXTUALIZATION GUARD
if [ "$1" != 'local' ] ; then
    exit 0
fi

if [ -n "${DISK_ID}" ] && [ "${DISK_ID}" -gt 0 ]; then
    DISK_COUNT="${DISK_ID}"
else
    exit 0
fi

is_mounted() {
    if command -v findmnt >/dev/null 2>&1; then
        findmnt -rn --mountpoint "$1" >/dev/null 2>&1
    else
        mount | awk '{print $3}' | grep -Fxq "$1"
    fi
}

disk_var() {
    local _idx="$1"
    local _key="$2"
    local _name="DISK${_idx}_${_key}"
    echo "${!_name}"
}

disk_is_defined() {
    local _idx="$1"
    compgen -A variable "DISK${_idx}_" >/dev/null 2>&1
}

for i in $(seq 0 $((DISK_COUNT - 1))); do
    if ! disk_is_defined "$i"; then
        continue
    fi

    MOUNTPOINT=$(disk_var "$i" "MOUNTPOINT")
    TARGET=$(disk_var "$i" "TARGET")
    FSTYPE=$(disk_var "$i" "FSTYPE")
    MOUNTOPTS=$(disk_var "$i" "MOUNTOPTS")
    if [ -z "${MOUNTPOINT}" ]; then
        continue
    fi

    if is_mounted "${MOUNTPOINT}"; then
        echo "DISK${i}: already mounted at ${MOUNTPOINT}"
        continue
    fi

    SOURCE=""
    # Try TARGET first
    if [ -n "${TARGET}" ]; then
        if [ -e "/dev/${TARGET}" ]; then
            # TARGET exists as a device node
            SOURCE="/dev/${TARGET}"
        fi
        # If /dev/${TARGET} doesn't exist,
        # leave SOURCE empty to trigger fallback via SERIAL/by-id lookup
    fi

    # Fallback: use DISK serial to find device via /dev/disk/by-id/
    if [ -z "${SOURCE}" ]; then
        SERIAL=$(disk_var "$i" "SERIAL")

        # Search for device by serial across all bus types
        for byid_path in \
            /dev/disk/by-id/scsi-*QEMU_QEMU_HARDDISK_${SERIAL} \
            /dev/disk/by-id/scsi-S*QEMU_QEMU_HARDDISK_${SERIAL} \
            /dev/disk/by-id/virtio-*${SERIAL}* \
            /dev/disk/by-id/ata-*${SERIAL}* \
            /dev/disk/by-id/*${SERIAL}*; do
            # Check if the glob matched any files
            # Skip partition symlinks (they contain -part in the name)
            if [ -e "${byid_path}" ] && [ -L "${byid_path}" ] && [ "${byid_path#*-part}" = "${byid_path}" ]; then
                SOURCE=$(readlink -f "${byid_path}")
                if [ -b "${SOURCE}" ]; then
                    break
                fi
            fi
        done
    fi

    if [ -z "${FSTYPE}" ] && [ "${SOURCE#/dev/}" != "${SOURCE}" ]; then
        if command -v blkid >/dev/null 2>&1; then
            FSTYPE=$(blkid -o value -s TYPE "${SOURCE}" 2>/dev/null | head -n1)
        fi
    fi

    mkdir -p "${MOUNTPOINT}"

    if [ -n "${MOUNTOPTS}" ] && [ -n "${FSTYPE}" ]; then
        mount -t "${FSTYPE}" -o "${MOUNTOPTS}" "${SOURCE}" "${MOUNTPOINT}"
    elif [ -n "${MOUNTOPTS}" ]; then
        mount -o "${MOUNTOPTS}" "${SOURCE}" "${MOUNTPOINT}"
    elif [ -n "${FSTYPE}" ]; then
        mount -t "${FSTYPE}" "${SOURCE}" "${MOUNTPOINT}"
    else
        mount "${SOURCE}" "${MOUNTPOINT}"
    fi

    if [ "$?" -eq 0 ]; then
        echo "DISK${i}: mounted ${SOURCE} on ${MOUNTPOINT}"
    else
        echo "DISK${i}: failed to mount ${SOURCE} on ${MOUNTPOINT}"
    fi
done
